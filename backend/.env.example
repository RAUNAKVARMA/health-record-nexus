# Local default: SQLite (works without Docker/Postgres install)
DATABASE_URL=sqlite:///./health_record.db

# When Docker Postgres is running, use:
# DATABASE_URL=postgresql+psycopg2://health:health@localhost:5432/health_record

JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
